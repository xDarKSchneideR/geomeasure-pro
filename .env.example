# .env.example - Copia este archivo a .env.local y completa los valores
# ⚠️ NUNCA commitees tu .env.local real al repositorio

# === FRONTEND (Netlify) ===
# URL base de tu API backend
VITE_API_BASE_URL=https://geomeasure-pro.onrender.com

# Opcional: URL personalizada para tiles de mapas
# VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# === BACKEND (Render) ===
# 🔐 CRÍTICO: Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# 🔐 CRÍTICO: Conexión a PostgreSQL (Neon)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Entorno de ejecución
NODE_ENV=production

# Puerto (Render lo asigna automáticamente)
PORT=

# === OPCIONAL: Configuración adicional ===
# LOG_LEVEL=info
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100